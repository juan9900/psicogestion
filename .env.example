# Supabase — copia a .env.local y rellena con los valores de tu proyecto.
# Settings → API en el panel de Supabase.

# Públicas (pueden ir en el cliente):
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key

# Secreta (SOLO servidor, nunca en componentes del cliente ni en el navegador):
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# PayPal — checkout de recursos. developer.paypal.com → tu app REST API.
# Pública (puede ir en el cliente):
NEXT_PUBLIC_PAYPAL_CLIENT_ID=tu_paypal_client_id

# Secretas (SOLO servidor):
PAYPAL_CLIENT_SECRET=tu_paypal_client_secret
# Sandbox mientras se prueba; en producción: https://api-m.paypal.com
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# Resend — correos transaccionales (link de descarga, avisos de orden).
# resend.com → API Keys. Secreta, SOLO servidor.
RESEND_API_KEY=tu_resend_api_key
# Remitente. Sin dominio propio verificado en Resend, solo se puede enviar a
# la dirección con la que te registraste; usa onboarding@resend.dev mientras tanto.
EMAIL_FROM=onboarding@resend.dev
# Bandeja donde Carmen recibe el aviso de cada orden nueva de pago móvil.
ADMIN_EMAIL=tu_correo@ejemplo.com
# URL pública del sitio, para armar el enlace a la orden en los correos.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
